# VORTE PRO - Environment Variables Example
# Copy this file to .env and fill in your real values

# Bot Settings
BOT_NAME="VORTE PRO"
PREFIX="."

# Owner Details (WhatsApp JIDs)
# Format: +255778271055 (with country code, no spaces or +)
OWNER_1="255778271055"
OWNER_2="6285863023532"

# Session & Storage
SESSION_FOLDER="./storage/session"

# API Keys
OPENAI_API_KEY="your_openai_api_key_here"
IMDB_API_KEY="your_omdb_api_key_here"
YOUTUBE_API_KEY="your_youtube_api_key_here"

# Server Settings
PORT=3000
